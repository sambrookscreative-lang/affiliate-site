---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Newsletter" description="Subscribe to receive weekly insights on AI automation and security best practices.">
  <div class="container" style="padding: 4rem 0; max-width: 600px; text-align: center;">
    <h1>Stay in the Loop</h1>
    <p style="font-size: 1.2rem; color: var(--text-secondary); margin: 2rem 0;">
      Get weekly insights on AI automation tools, security best practices, and exclusive deals.
    </p>

    <form class="newsletter-form" style="margin: 3rem 0;">
      <input type="email" placeholder="your@email.com" required>
      <button type="submit">Subscribe</button>
    </form>

    <p style="font-size: 0.9rem; color: var(--text-secondary);">
      No spam, ever. Unsubscribe with one click.
    </p>

    <div style="margin-top: 4rem; text-align: left;">
      <h2 style="font-size: 1.5rem; margin-bottom: 1rem;">What You'll Get:</h2>
      <ul style="line-height: 2; list-style: none; padding: 0;">
        <li>📬 Weekly tool reviews and comparisons</li>
        <li>🔒 Security tips for your automation stack</li>
        <li>💰 Exclusive deals and early access</li>
        <li>📊 Industry trends and insights</li>
      </ul>
    </div>
  </div>
</BaseLayout>

<style>
  h1 {
    font-size: 3rem;
    color: var(--primary);
  }

  .newsletter-form {
    display: flex;
    gap: 1rem;
  }

  .newsletter-form input {
    flex: 1;
    padding: 1rem;
    background: var(--bg-card);
    border: 1px solid #333;
    border-radius: 5px;
    color: var(--text-primary);
    font-size: 1rem;
  }

  .newsletter-form button {
    padding: 1rem 2rem;
    background: var(--primary);
    color: #000;
    border: none;
    border-radius: 5px;
    font-weight: bold;
    cursor: pointer;
    font-size: 1rem;
  }

  .newsletter-form button:hover {
    opacity: 0.9;
  }
</style>
