---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="Discover the best AI automation and cybersecurity tools to scale your business securely.">
  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <div class="badge">🚀 Trusted by 10,000+ businesses</div>
        <h1 class="hero-title">
          Scale Your Business with
          <span class="gradient-text">AI Automation</span>
          <br>Without Compromising Security
        </h1>
        <p class="hero-subtitle">
          Expert reviews and comparisons of the best AI tools and cybersecurity solutions. 
          Make informed decisions, automate fearlessly.
        </p>
        <div class="hero-cta">
          <a href="/reviews" class="btn-primary">Browse Reviews</a>
          <a href="/blog" class="btn-secondary">Read Guides</a>
        </div>
        <div class="trust-badges">
          <span>✓ Hands-on tested</span>
          <span>✓ No BS reviews</span>
          <span>✓ Security-first</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="features">
    <div class="container">
      <div class="section-header">
        <h2>Why SecureAutomation?</h2>
        <p>We bridge the gap between power and protection</p>
      </div>
      <div class="feature-grid">
        <div class="feature-card">
          <div class="feature-icon">🤖</div>
          <h3>AI Automation</h3>
          <p>HubSpot, Scalenut, and cutting-edge tools that scale your business without the headcount.</p>
          <a href="/reviews" class="feature-link">Explore tools →</a>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔒</div>
          <h3>Enterprise Security</h3>
          <p>NordLayer, Surfshark, and battle-tested solutions to protect your automation stack.</p>
          <a href="/reviews" class="feature-link">View security →</a>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📊</div>
          <h3>Data-Driven Reviews</h3>
          <p>Real testing, honest opinions, zero fluff. We only recommend what we'd use ourselves.</p>
          <a href="/about" class="feature-link">Our process →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Tools -->
  <section class="featured-tools">
    <div class="container">
      <div class="section-header">
        <h2>Top Rated Tools</h2>
        <p>The tools we actually recommend</p>
      </div>
      <div class="tools-grid">
        <div class="tool-card">
          <div class="tool-header">
            <h3>HubSpot</h3>
            <span class="badge-small">AI Automation</span>
          </div>
          <p>All-in-one CRM and marketing automation. 30% recurring commission for 12 months.</p>
          <div class="tool-meta">
            <span>⭐ 4.5/5</span>
            <span>💰 High-ticket</span>
          </div>
          <a href="#" class="tool-link">Read review →</a>
        </div>
        <div class="tool-card">
          <div class="tool-header">
            <h3>Scalenut</h3>
            <span class="badge-small">AI Content</span>
          </div>
          <p>SEO content lifecycle tool. 30-50% lifetime recurring commissions.</p>
          <div class="tool-meta">
            <span>⭐ 4.7/5</span>
            <span>💰 Lifetime</span>
          </div>
          <a href="#" class="tool-link">Read review →</a>
        </div>
        <div class="tool-card">
          <div class="tool-header">
            <h3>NordLayer</h3>
            <span class="badge-small">Security</span>
          </div>
          <p>Business VPN with lifetime revenue share. Enterprise-grade protection.</p>
          <div class="tool-meta">
            <span>⭐ 4.6/5</span>
            <span>🔒 Enterprise</span>
          </div>
          <a href="#" class="tool-link">Read review →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="newsletter-section">
    <div class="container">
      <div class="newsletter-box">
        <h2>Stay Ahead of the Curve</h2>
        <p>Weekly insights on AI automation, security best practices, and exclusive deals.</p>
        <form class="newsletter-form">
          <input type="email" placeholder="your@email.com" required>
          <button type="submit">Subscribe Free</button>
        </form>
        <p class="newsletter-note">Join 5,000+ readers. No spam, unsubscribe anytime.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero Section */
  .hero {
    padding: 6rem 0 4rem;
    background: linear-gradient(180deg, var(--bg-darker) 0%, var(--bg-dark) 100%);
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid rgba(16, 185, 129, 0.3);
    border-radius: 20px;
    color: var(--primary);
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 2rem;
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    letter-spacing: -1px;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--primary) 0%, #06b6d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .btn-primary, .btn-secondary {
    padding: 1rem 2rem;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.2s;
  }

  .btn-primary {
    background: var(--primary);
    color: #000;
    box-shadow: 0 4px 14px rgba(16, 185, 129, 0.4);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(16, 185, 129, 0.5);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-primary);
    border: 2px solid var(--border);
  }

  .btn-secondary:hover {
    border-color: var(--primary);
    color: var(--primary);
  }

  .trust-badges {
    display: flex;
    gap: 2rem;
    justify-content: center;
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  /* Features Section */
  .features {
    padding: 5rem 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-header h2 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .section-header p {
    color: var(--text-secondary);
    font-size: 1.125rem;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .feature-card {
    padding: 2.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    transition: all 0.3s;
  }

  .feature-card:hover {
    border-color: var(--primary);
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(16, 185, 129, 0.2);
  }

  .feature-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .feature-card p {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .feature-link {
    color: var(--primary);
    font-weight: 600;
    text-decoration: none;
  }

  .feature-link:hover {
    text-decoration: underline;
  }

  /* Featured Tools */
  .featured-tools {
    padding: 5rem 0;
    background: var(--bg-darker);
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .tool-card {
    padding: 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    transition: all 0.3s;
  }

  .tool-card:hover {
    border-color: var(--primary);
    transform: translateY(-2px);
  }

  .tool-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .tool-header h3 {
    font-size: 1.5rem;
  }

  .badge-small {
    padding: 0.25rem 0.75rem;
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid rgba(16, 185, 129, 0.3);
    border-radius: 12px;
    font-size: 0.75rem;
    color: var(--primary);
    font-weight: 600;
  }

  .tool-card p {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .tool-meta {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .tool-link {
    color: var(--primary);
    font-weight: 600;
    text-decoration: none;
  }

  .tool-link:hover {
    text-decoration: underline;
  }

  /* Newsletter Section */
  .newsletter-section {
    padding: 5rem 0;
  }

  .newsletter-box {
    max-width: 600px;
    margin: 0 auto;
    padding: 3rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    text-align: center;
  }

  .newsletter-box h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .newsletter-box > p {
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .newsletter-form {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .newsletter-form input {
    flex: 1;
    padding: 1rem 1.25rem;
    background: var(--bg-dark);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text-primary);
    font-size: 1rem;
  }

  .newsletter-form input:focus {
    outline: none;
    border-color: var(--primary);
  }

  .newsletter-form button {
    padding: 1rem 2rem;
    background: var(--primary);
    color: #000;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .newsletter-form button:hover {
    background: var(--primary-dark);
    transform: translateY(-1px);
  }

  .newsletter-note {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.5rem;
    }

    .hero-subtitle {
      font-size: 1.125rem;
    }

    .hero-cta {
      flex-direction: column;
    }

    .trust-badges {
      flex-direction: column;
      gap: 0.5rem;
    }

    .section-header h2 {
      font-size: 2rem;
    }

    .newsletter-form {
      flex-direction: column;
    }

    .newsletter-box {
      padding: 2rem 1.5rem;
    }
  }
</style>

<style>
  /* Hero with animated gradient background */
  .hero {
    padding: 6rem 0 4rem;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.05) 0%, rgba(79, 70, 229, 0.05) 100%);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.1) 0%, transparent 70%);
    animation: pulse 8s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.1); opacity: 0.8; }
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(99, 102, 241, 0.1);
    border: 1px solid rgba(99, 102, 241, 0.3);
    border-radius: 20px;
    color: var(--primary-light);
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 2rem;
    backdrop-filter: blur(10px);
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    letter-spacing: -0.03em;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .btn-primary, .btn-secondary {
    padding: 1rem 2rem;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    min-width: 150px;
    text-align: center;
  }

  .btn-primary {
    background: var(--primary);
    color: #fff;
    box-shadow: 0 4px 14px rgba(99, 102, 241, 0.4);
  }

  .btn-primary:hover {
    background: var(--primary-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(99, 102, 241, 0.5);
    color: #fff;
  }

  .btn-secondary {
    background: rgba(99, 102, 241, 0.1);
    color: var(--text-primary);
    border: 2px solid rgba(99, 102, 241, 0.3);
    backdrop-filter: blur(10px);
  }

  .btn-secondary:hover {
    border-color: var(--primary);
    background: rgba(99, 102, 241, 0.2);
    color: var(--primary-light);
  }

  .trust-badges {
    display: flex;
    gap: 2rem;
    justify-content: center;
    font-size: 0.875rem;
    color: var(--text-secondary);
    flex-wrap: wrap;
  }

  /* Features with glass-morphism */
  .features {
    padding: 5rem 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-header h2 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin-bottom: 0.5rem;
  }

  .section-header p {
    color: var(--text-secondary);
    font-size: 1.125rem;
  }

  .feature-grid, .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .feature-card, .tool-card {
    padding: 2.5rem;
    backdrop-filter: blur(16px);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .feature-card:hover, .tool-card:hover {
    border-color: var(--primary);
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(99, 102, 241, 0.2);
  }

  .feature-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    filter: drop-shadow(0 4px 8px rgba(99, 102, 241, 0.3));
  }

  .feature-card h3, .tool-card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .feature-card p, .tool-card p {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .feature-link, .tool-link {
    color: var(--primary-light);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .feature-link:hover, .tool-link:hover {
    color: var(--primary);
    text-decoration: none;
  }

  /* Featured Tools */
  .featured-tools {
    padding: 5rem 0;
    background: var(--bg-darker);
  }

  .tool-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .badge-small {
    padding: 0.375rem 0.875rem;
    background: rgba(99, 102, 241, 0.15);
    border: 1px solid rgba(99, 102, 241, 0.3);
    border-radius: 12px;
    font-size: 0.75rem;
    color: var(--primary-light);
    font-weight: 600;
    backdrop-filter: blur(8px);
  }

  .tool-meta {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  /* Newsletter with premium styling */
  .newsletter-section {
    padding: 5rem 0;
  }

  .newsletter-box {
    max-width: 600px;
    margin: 0 auto;
    padding: 3rem;
    backdrop-filter: blur(16px);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 20px;
    text-align: center;
    box-shadow: 0 8px 32px rgba(99, 102, 241, 0.15);
  }

  .newsletter-box h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .newsletter-box > p {
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .newsletter-form {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .newsletter-form input {
    flex: 1;
    padding: 1rem 1.25rem;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text-primary);
    font-size: 1rem;
    transition: all 0.2s;
  }

  .newsletter-form input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
  }

  .newsletter-form button {
    padding: 1rem 2rem;
    background: var(--primary);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 14px rgba(99, 102, 241, 0.4);
  }

  .newsletter-form button:hover {
    background: var(--primary-dark);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(99, 102, 241, 0.5);
  }

  .newsletter-note {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .newsletter-form {
      flex-direction: column;
    }

    .newsletter-box {
      padding: 2rem 1.5rem;
    }

    .tools-grid, .feature-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
